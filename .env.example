TELEGRAM_BOT_TOKEN=
# Chat_id админов через запятую (узнать: написать @userinfobot из своего ТГ).
# Для группового чата id отрицательный, для лички — положительный.
TELEGRAM_ADMIN_CHAT_IDS=
# Час суток (0-23), в который шлётся ежедневная сводка "за день до возврата".
TELEGRAM_REMINDER_HOUR=9
